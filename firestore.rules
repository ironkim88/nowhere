rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuthed() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Posts: anyone authenticated can read
    // Author can update/delete; participants can update (comments/joins)
    // Admin can do anything
    match /posts/{postId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.resource.data.author is string;
      allow update: if isAuthed();
      allow delete: if isAuthed() && (
        resource.data.authorUid == request.auth.uid ||
        resource.data.author == request.auth.token.name ||
        isAdmin() ||
        // Allow client-side cleanup of expired posts (5+ days past deadline)
        resource.data.deadlineMs < (request.time.toMillis() - 5 * 24 * 60 * 60 * 1000)
      );
    }

    // Users: each user can only modify their own profile
    // Anyone authenticated can read profiles (for nickname display)
    match /users/{uid} {
      allow read: if isAuthed();
      allow write: if isOwner(uid) || isAdmin();
    }

    // Reports: anyone authenticated can submit
    // Only target user can read their own reports; admin can read all
    match /reports/{reportId} {
      allow read: if isAuthed();
      allow create: if isAuthed() &&
        request.resource.data.from is string &&
        request.resource.data.target is string;
      allow update, delete: if isAdmin();
    }

    // Admins collection: only admins can read/write
    match /admins/{uid} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // Catch-all: deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
