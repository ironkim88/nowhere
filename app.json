{
  "expo": {
    "name": "지금, 여기",
    "slug": "nowhere",
    "owner": "ironkims-organization",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "nowhereapp",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#3182F6",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ironkim88.nowhere",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "주변 모임을 찾기 위해 위치 정보가 필요해요.",
        "NSCameraUsageDescription": "도착 인증 사진 촬영을 위해 카메라가 필요해요.",
        "NSPhotoLibraryUsageDescription": "모임 사진을 첨부하기 위해 사진 라이브러리 접근이 필요해요."
      }
    },
    "android": {
      "package": "com.ironkim88.nowhere",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3182F6"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "지금, 여기",
      "shortName": "지금여기",
      "themeColor": "#3182F6",
      "backgroundColor": "#FFFFFF",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "주변 모임을 찾기 위해 위치 정보가 필요해요."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "모임 사진 첨부를 위해 사진 라이브러리 접근이 필요해요.",
          "cameraPermission": "도착 인증 사진 촬영을 위해 카메라가 필요해요."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "50a5b87a-01dc-49e7-a6a8-5c174619be5a"
      }
    }
  }
}
